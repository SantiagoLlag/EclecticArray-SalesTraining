---
import agents from '../data/agents.json';
import products from '../data/products.json';
import quiz from '../data/quiz-questions.json';
import stores from '../data/stores.json';
import '../styles/global.css';

// An agent is usable only when the composer has written a real ElevenLabs id.
const isConfigured = (id: unknown): boolean =>
  typeof id === 'string' && id.length >= 10 && !/todo|placeholder|xxx|[<>]/i.test(id);

// Shopify CDN accepts ?width= for resizing; keep hotlinks light.
const cdn = (url: string, width: number) =>
  `${url}${url.includes('?') ? '&' : '?'}width=${width}`;

// Category chips, in order of first appearance in products.json (UI-only metadata —
// it never travels to the agent).
const categories = [...new Set(products.map((p) => p.category).filter(Boolean))];

// Pieces shown inside the tutorial's animated mini-screens (real catalog data,
// so the tutorial never drifts from the shop).
const tutFootwear = products.find((p) => p.category === 'Footwear') ?? products[0];
const tutJewelry = products.find((p) => p.category === 'Jewelry') ?? products[0];

const appData = JSON.stringify({ agents, products, quiz, stores }).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fbf6ef" />
    <meta
      name="description"
      content="Practice selling Eclectic Array pieces against a simulated customer — by voice."
    />
    <title>Sales Trainer — Eclectic Array</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Instrument+Serif:ital@1&display=swap"
    />
  </head>

  <body data-view="start">
    <div class="shell">
      <header class="topbar">
        <button class="back" id="btn-back" type="button">&larr; Back</button>
        <span class="wordmark">Eclectic Array <span>&mdash;</span> Sales Trainer</span>
        <div class="store-chip" id="store-chip" hidden>
          <span class="store-here">
            <span class="store-dot" aria-hidden="true">&#9673;</span>
            <strong id="store-name"></strong>
          </span>
          <button class="linklike" id="btn-switch-store" type="button">Switch</button>
        </div>
      </header>

      <!-- 1 · Start -->
      <section id="view-start" class="view is-active" aria-label="Start">
        <div class="hero">
          <p class="eyebrow">Eclectic Array &mdash; Sales Trainer</p>
          <h1>Sell it like<br /><span class="serif">it's real.</span></h1>
          <div class="rule" aria-hidden="true"></div>
          <p class="tagline">Practice with a customer before the real one walks in.</p>
          <button class="btn-primary" id="btn-start" type="button">Start Training</button>
          <button class="btn-tutorial" id="btn-tutorial" type="button">
            First time? Watch the tutorial
          </button>
          <p class="footnote trainee-chip" id="trainee-chip" hidden>
            Training as <strong id="trainee-name"></strong>
            <button class="linklike" id="btn-my-progress" type="button">My progress</button>
            <button class="linklike" id="btn-switch-seller" type="button">Switch</button>
          </p>
          <p class="footnote">Los Cabos &middot; Nevis</p>
        </div>
      </section>

      <!-- 1b · Who's training (kiosk roster + PIN) -->
      <section id="view-who" class="view" aria-label="Who is training">
        <p class="eyebrow">Before you start</p>
        <h1 class="screen-title">Who&rsquo;s training?</h1>
        <p class="screen-sub">
          Tap your name and enter your PIN. Your sessions and progress are saved to your
          record &mdash; visible to you and to management.
        </p>

        <div id="who-pick">
          <div class="card-list who-list" role="listbox" aria-label="Sellers" id="who-list"></div>
          <button class="btn-ghost" id="btn-who-guest" type="button">
            Continue as guest &mdash; nothing gets saved
          </button>
        </div>

        <div id="who-pin" class="pin-panel" hidden>
          <p class="screen-sub" id="who-pin-name"></p>
          <input
            id="pin-input"
            class="pin-input"
            type="password"
            inputmode="numeric"
            autocomplete="off"
            maxlength="8"
            placeholder="PIN"
            aria-label="PIN"
          />
          <p class="pin-error" id="pin-error" hidden>Wrong PIN &mdash; try again.</p>
          <div class="pin-actions">
            <button class="btn-primary" id="btn-pin-go" type="button">Enter</button>
            <button class="btn-ghost" id="btn-pin-back" type="button">Back</button>
          </div>
        </div>
      </section>

      <!-- 1b2 · Which store (sets the floor: only this store's pieces show) -->
      <section id="view-store" class="view" aria-label="Choose your store">
        <p class="eyebrow">One more thing</p>
        <h1 class="screen-title">Which store are you in?</h1>
        <p class="screen-sub">
          You&rsquo;ll practice with the pieces on this store&rsquo;s floor. You can switch
          anytime from the top corner.
        </p>
        <div class="card-list store-list" role="listbox" aria-label="Stores" id="store-list">
          {stores.map((s) => (
            <button
              class="card customer-card store-card"
              type="button"
              role="option"
              aria-selected="false"
              data-store-id={s.id}
            >
              <div class="card-body"><h2>{s.name}</h2></div>
            </button>
          ))}
        </div>
      </section>

      <!-- 1c · My progress (the signed-in seller's own record) -->
      <section id="view-progress" class="view" aria-label="My progress">
        <p class="eyebrow">Your record</p>
        <h1 class="screen-title" id="prog-title">My progress</h1>
        <p class="screen-sub" id="prog-sub">Loading&hellip;</p>

        <div class="prog-stats" id="prog-stats"></div>

        <div class="progress-grid">
          <section class="report-card">
            <h2>Practice this next</h2>
            <p class="prog-next" id="prog-next"></p>
          </section>

          <section class="report-card">
            <h2>From your last reports</h2>
            <ol class="improvements" id="prog-improve"></ol>
          </section>

          <section class="report-card">
            <h2>Recent weeks</h2>
            <ul class="coverage" id="prog-weeks"></ul>
          </section>

          <section class="report-card">
            <h2>Inventory quiz</h2>
            <ul class="coverage" id="prog-quiz"></ul>
          </section>

          <section class="report-card prog-sessions-card">
            <h2>Recent sessions <span class="score" id="prog-session-count"></span></h2>
            <div class="prog-sessions" id="prog-sessions"></div>
          </section>
        </div>
      </section>

      <!-- 2 · Training dashboard: two tracks -->
      <section id="view-agents" class="view" aria-label="Training dashboard">
        <p class="eyebrow">Training dashboard</p>
        <h1 class="screen-title">What do you want to practice?</h1>
        <p class="screen-sub">Two ways to train: face a customer and close the sale, or roam the floor and master your inventory.</p>

        {(() => {
          const indexed = agents.map((agent, i) => ({ agent, i }));
          // Track A is an explicit allow-list (no mode = the 4 personas; mentor = the flipped
          // masterclass) so a future mode never lands under "Sell to a customer" by default.
          const customers = indexed.filter((x) => !x.agent.mode || x.agent.mode === 'mentor');
          const inventory = indexed.filter((x) => x.agent.mode === 'inventory');
          // Mystery pools only over the close-the-sale personas (see pickAgent), so its card
          // must gate on THOSE being ready — not on any two agents.
          const mysteryReady = agents.filter(
            (a) => isConfigured(a.agent_id) && !a.mode
          ).length;
          return (
            <>
              <div class="track-switch" id="track-switch">
                <div class="track-panel" data-track="customers">
                  <button class="track-toggle" type="button" data-select-track="customers">
                    <span class="track-num">A</span>
                    <span class="track-toggle-text">
                      <span class="track-title">Sell to a customer</span>
                      <span class="track-sub">Pick who walks in, then the piece on the counter. Practice discovery, the story, objections, and the close.</span>
                    </span>
                    <span class="track-cue" aria-hidden="true">Choose →</span>
                  </button>
                  <div class="track-cards">
                    <div class="card-list" role="listbox" aria-label="Customer types" id="agent-list">
                      {customers.map(({ agent, i }, pos) => {
                        const ready = isConfigured(agent.agent_id);
                        return (
                          <button
                            class="card customer-card"
                            type="button"
                            role="option"
                            aria-selected="false"
                            data-agent-index={i}
                            disabled={!ready}
                          >
                            <div class="card-body">
                              <span class="index">{String(pos + 1).padStart(2, '0')}</span>
                              <h2>{agent.label}</h2>
                              <p>{agent.description}</p>
                              {!ready && <span class="badge-unavailable">Not available yet</span>}
                            </div>
                          </button>
                        );
                      })}
                      {mysteryReady >= 2 && (
                        <button
                          class="card customer-card mystery-card"
                          type="button"
                          role="option"
                          aria-selected="false"
                          data-mystery
                        >
                          <div class="card-body">
                            <span class="index">?</span>
                            <h2>Mystery Customer</h2>
                            <p>
                              Whoever walks in, walks in. You won't know who you sold to until your
                              results — practice reading the customer cold.
                            </p>
                          </div>
                        </button>
                      )}
                    </div>
                  </div>
                </div>

                {inventory.length > 0 && (
                  <div class="track-panel" data-track="inventory">
                    <button class="track-toggle" type="button" data-select-track="inventory">
                      <span class="track-num">B</span>
                      <span class="track-toggle-text">
                        <span class="track-title">Know your inventory</span>
                        <span class="track-sub">A curious browser roams the whole floor, piece after piece. No product to pick — you're off the moment they point. Practice telling every story right, and staying eloquent on your feet.</span>
                      </span>
                      <span class="track-cue" aria-hidden="true">Choose →</span>
                    </button>
                    <div class="track-cards">
                      <div class="card-list" role="listbox" aria-label="Inventory training" id="inventory-list">
                        {inventory.map(({ agent, i }) => {
                          const ready = isConfigured(agent.agent_id);
                          return (
                            <button
                              class="card customer-card inventory-card"
                              type="button"
                              role="option"
                              aria-selected="false"
                              data-agent-index={i}
                              disabled={!ready}
                            >
                              <div class="card-body">
                                <span class="index">★</span>
                                <h2>{agent.label}</h2>
                                <p>{agent.description}</p>
                                {!ready && <span class="badge-unavailable">Not available yet</span>}
                              </div>
                            </button>
                          );
                        })}
                        <button
                          class="card customer-card inventory-card quiz-card"
                          type="button"
                          role="option"
                          aria-selected="false"
                          data-quiz
                        >
                          <div class="card-body">
                            <span class="index">✎</span>
                            <h2>Inventory Quiz</h2>
                            <p>A fast multiple-choice drill on every piece — origin, maker, technique, price. Fresh questions each round; you learn the true story as you go.</p>
                          </div>
                        </button>
                      </div>
                    </div>
                  </div>
                )}
              </div>

              {agents.length === 0 && (
                <p class="screen-sub">No customers available yet — check back soon.</p>
              )}
            </>
          );
        })()}
      </section>

      <!-- 3 · Choose the product -->
      <section id="view-products" class="view" aria-label="Choose the product">
        <p class="eyebrow">Step 2 of 2</p>
        <h1 class="screen-title">Choose the product</h1>
        <p class="screen-sub" id="products-sub">This is the piece on the counter. Know it before they ask.</p>

        {categories.length > 1 && (
          <div class="chips" role="group" aria-label="Filter by category" id="category-chips">
            <button class="chip" type="button" data-category="all" aria-pressed="true">All</button>
            {categories.map((c) => (
              <button class="chip" type="button" data-category={c} aria-pressed="false">{c}</button>
            ))}
          </div>
        )}

        <div class="card-list products" role="listbox" aria-label="Products" id="product-list">
          {
            products.map((product, i) => (
              <button
                class="card product-card"
                type="button"
                role="option"
                aria-selected="false"
                data-product-index={i}
                data-category={product.category}
                data-stores={((product as { stores?: string[] }).stores ?? []).join(',')}
              >
                <figure>
                  <img
                    src={cdn(product.image, 720)}
                    alt={product.name}
                    width="720"
                    height="720"
                    loading="lazy"
                    onerror={`this.onerror=null;this.src='/products/${product.id}.png'`}
                  />
                </figure>
                <div class="card-body">
                  <h2>{product.name}</h2>
                  <p class="price">{product.price}</p>
                  <p>{product.description}</p>
                </div>
              </button>
            ))
          }
        </div>
      </section>

      <!-- Quiz · Lobby -->
      <section id="view-quiz-setup" class="view" aria-label="Inventory quiz">
        <p class="eyebrow">Know your inventory</p>
        <h1 class="screen-title">Inventory quiz</h1>
        <p class="screen-sub">Multiple choice on the true story of every piece. Fresh questions each round.</p>
        <div class="card-list quiz-modes" role="listbox" aria-label="Quiz length">
          <button class="card customer-card" type="button" role="option" aria-selected="false" data-quiz-mode="quick">
            <div class="card-body">
              <span class="index">10</span>
              <h2>Quick round</h2>
              <p>Ten questions across the floor. About two minutes.</p>
            </div>
          </button>
          <button class="card customer-card" type="button" role="option" aria-selected="false" data-quiz-mode="full">
            <div class="card-body">
              <span class="index">28</span>
              <h2>Full floor</h2>
              <p>One question per piece — every item in the shop. About six minutes.</p>
            </div>
          </button>
        </div>
      </section>

      <!-- Quiz · Question -->
      <section id="view-quiz" class="view" aria-label="Quiz question">
        <div class="quiz-top">
          <div class="quiz-progress">
            <span id="quiz-count"></span>
            <span class="quiz-score" id="quiz-score"></span>
          </div>
          <div class="quiz-bar" aria-hidden="true"><span id="quiz-bar-fill"></span></div>
        </div>
        <div class="quiz-stage">
          <div class="quiz-piece">
            <img id="quiz-thumb" class="quiz-photo" src="" alt="The piece shown" width="240" height="240" />
          </div>
          <p class="quiz-prompt" id="quiz-prompt"></p>
          <div class="quiz-options" id="quiz-options" role="group" aria-label="Answer options"></div>
          <div class="quiz-feedback" id="quiz-feedback" aria-live="polite" hidden></div>
          <div class="quiz-actions">
            <button class="btn-primary" id="btn-quiz-next" type="button" hidden>Next</button>
          </div>
        </div>
      </section>

      <!-- Quiz · Results -->
      <section id="view-quiz-results" class="view" aria-label="Quiz results">
        <p class="eyebrow">Inventory quiz</p>
        <h1 class="screen-title" id="quiz-result-title"></h1>
        <p class="report-context" id="quiz-result-score"></p>
        <div class="report-grid">
          <section class="report-card" id="quiz-weak-wrap">
            <h2>Worth another look</h2>
            <ul class="coverage" id="quiz-weak"></ul>
          </section>
        </div>
        <div class="report-actions">
          <button class="btn-primary" id="btn-quiz-again" type="button">Try again</button>
          <button class="btn-ghost" id="btn-quiz-home" type="button">Back to start</button>
        </div>
      </section>

      <!-- 5 · Results -->
      <section id="view-report" class="view" aria-label="Session results">
        <p class="eyebrow">Session results</p>
        <h1 class="screen-title" id="report-outcome"></h1>
        <p class="report-quote serif" id="report-quote"></p>
        <p class="report-ticket" id="report-ticket" hidden>
          <span class="label">Ticket</span>
          <strong id="report-ticket-amount"></strong>
          <span class="note" id="report-ticket-note"></span>
        </p>
        <p class="report-context" id="report-context"></p>

        <div class="report-grid">
          <p class="report-summary" id="report-summary"></p>

          <section class="report-card" id="report-criteria-wrap">
            <h2>Evaluation criteria <span class="score" id="report-criteria-score"></span></h2>
            <ul class="coverage criteria" id="report-criteria"></ul>
          </section>

          <section class="report-card">
            <h2 id="report-story-title">Know your piece</h2>
            <ul class="coverage" id="report-story"></ul>
          </section>

          <section class="report-card">
            <h2 id="report-objections-title">Objections</h2>
            <ul class="objections" id="report-objections"></ul>
          </section>

          <section class="report-card" id="report-best-wrap">
            <h2>Best moment</h2>
            <blockquote class="serif" id="report-best"></blockquote>
          </section>

          <section class="report-card">
            <h2 id="report-improvements-title">Next time</h2>
            <ol class="improvements" id="report-improvements"></ol>
          </section>

          <details class="report-transcript">
            <summary>Full transcript</summary>
            <div class="transcript-lines" id="report-transcript"></div>
          </details>
        </div>

        <div class="report-actions">
          <button class="btn-primary" id="btn-report-done" type="button">Practice again</button>
          <button class="btn-ghost" id="btn-download-analysis" type="button">Download analysis</button>
          <button class="btn-ghost" id="btn-download" type="button">Download transcript</button>
        </div>
      </section>

      <!-- 4 · Session -->
      <section id="view-session" class="view" aria-label="Training session">
        <div class="session-grid">
          <aside class="crib" aria-label="Your piece">
            <span class="customer-chip" id="session-customer"></span>
            <div class="product-row">
              <img class="thumb" id="session-thumb" src="" alt="" width="72" height="72" />
              <div>
                <h2 id="session-product"></h2>
                <p class="price" id="session-price"></p>
              </div>
            </div>
            <p class="roam-trail" id="session-roam" hidden></p>
            <details id="session-story-wrap" open>
              <summary>Know your piece</summary>
              <ul id="session-story"></ul>
            </details>
            <details id="session-objections-wrap">
              <summary>Objections to expect</summary>
              <ul id="session-objections"></ul>
            </details>
          </aside>

          <div class="call">
            <div class="orb is-idle" id="orb" aria-hidden="true"></div>
            <p class="status-title" id="status-title" role="status" aria-live="polite"></p>
            <p class="status-sub" id="status-sub"></p>
            <div class="actions">
              <button class="btn-primary" id="btn-begin" type="button" hidden>Start Training</button>
              <button class="btn-end" id="btn-end" type="button" hidden>End session</button>
              <button class="btn-ghost" id="btn-retry" type="button" hidden>Try again</button>
              <button class="btn-ghost" id="btn-retry-report" type="button" hidden>Retry analysis</button>
              <button class="btn-ghost" id="btn-home" type="button" hidden>Back to start</button>
            </div>
            <div class="transcript" id="transcript" aria-label="Live transcript"></div>
          </div>
        </div>
      </section>
    </div>

    <!-- Tutorial: a guided, animated walkthrough of the screens the seller will see -->
    <div class="tutorial" id="tutorial" role="dialog" aria-modal="true" aria-label="Tutorial" hidden>
      <div class="tut-frame">
        <header class="tut-top">
          <span class="tut-brand">Tutorial</span>
          <button class="tut-close" id="tut-close" type="button" aria-label="Close tutorial">&times;</button>
        </header>

        <!-- 1 · What is this -->
        <section class="tut-step" data-step="0">
          <div class="tut-stage tut-intro">
            <div class="mini-path">
              <div class="mini-frame f1"><span class="mini-num">1</span>Customer</div>
              <span class="mini-arrow a1" aria-hidden="true">&rarr;</span>
              <div class="mini-frame f2"><span class="mini-num">2</span>Piece</div>
              <span class="mini-arrow a2" aria-hidden="true">&rarr;</span>
              <div class="mini-frame f3"><span class="mini-num">3</span>Talk</div>
            </div>
          </div>
          <h2>A practice floor</h2>
          <p>
            You'll sell — out loud, by voice — to a simulated customer who walks into the
            boutique. Three taps and the conversation starts; every session ends with a
            coaching report.
          </p>
        </section>

        <!-- 2 · Choose your customer -->
        <section class="tut-step" data-step="1">
          <div class="tut-stage tut-customers">
            <div class="mini-card pick">
              <span class="mini-index">01</span>
              <strong>{agents[0]?.label ?? 'The Haggler'}</strong>
              <span>Pushes for a discount from hello.</span>
            </div>
            <div class="mini-card">
              <span class="mini-index">02</span>
              <strong>{agents[1]?.label ?? 'The Collector'}</strong>
              <span>Tests if you know the real story.</span>
            </div>
            <div class="mini-card mini-mystery">
              <span class="mini-index">?</span>
              <strong>Mystery Customer</strong>
              <span>Revealed only in your results.</span>
            </div>
            <span class="tap" aria-hidden="true"></span>
          </div>
          <h2>Pick who walks in</h2>
          <p>
            Each customer trains a different muscle — price pressure, provenance questions,
            the easy yes you can still lose. Feeling brave? Mystery hides who it is until
            the session ends.
          </p>
        </section>

        <!-- 3 · Choose the product -->
        <section class="tut-step" data-step="2">
          <div class="tut-stage tut-products">
            <div class="mini-chips">
              <span class="mini-chip on">All</span>
              <span class="mini-chip target">Jewelry</span>
              <span class="mini-chip">Footwear</span>
            </div>
            <div class="mini-grid">
              <div class="mini-product fades">
                <img src={cdn(tutFootwear.image, 160)} alt="" width="56" height="56" loading="lazy" />
                <span class="mini-product-name">{tutFootwear.name}</span>
                <em>{tutFootwear.price}</em>
              </div>
              <div class="mini-product pick">
                <img src={cdn(tutJewelry.image, 160)} alt="" width="56" height="56" loading="lazy" />
                <span class="mini-product-name">{tutJewelry.name}</span>
                <em>{tutJewelry.price}</em>
              </div>
            </div>
            <span class="tap" aria-hidden="true"></span>
          </div>
          <h2>Pick the piece on the counter</h2>
          <p>
            Filter by category and choose what you're selling. Its &ldquo;Know your
            piece&rdquo; story and likely objections stay on screen the whole call —
            that's your crib sheet.
          </p>
        </section>

        <!-- 4 · The session -->
        <section class="tut-step" data-step="3">
          <div class="tut-stage tut-session">
            <div class="mini-crib">
              <span class="mini-chip-label">The Haggler</span>
              <strong>{tutJewelry.name} &middot; {tutJewelry.price}</strong>
              <span class="mini-bullet">&mdash; {tutJewelry.story[0]}</span>
            </div>
            <div class="mini-call">
              <span class="mini-orb" aria-hidden="true"></span>
              <p class="mini-line l1"><b>You</b>Welcome in! Looking for something special?</p>
              <p class="mini-line l2"><b>Customer</b>These are lovely — but at this price?</p>
            </div>
          </div>
          <h2>Talk like it's real</h2>
          <p>
            Tap Start Training and greet them — you speak first, like on the floor. The orb
            shows who's talking; your crib sheet stays beside you. The customer decides
            when the deal closes.
          </p>
        </section>

        <!-- 5 · The results -->
        <section class="tut-step" data-step="4">
          <div class="tut-stage tut-results">
            <strong class="mini-outcome">Sold.</strong>
            <p class="mini-ticket"><span>Ticket</span><em>{tutJewelry.price}</em>one at full price</p>
            <ul class="mini-criteria">
              <li class="c1"><span class="ok">&#10003;</span>Warm welcome</li>
              <li class="c2"><span class="ok">&#10003;</span>Product knowledge demonstrated</li>
              <li class="c3"><span class="no">&#10007;</span>Sale attempted</li>
            </ul>
          </div>
          <h2>Read your results</h2>
          <p>
            Claude reviews the transcript: the five evaluation criteria, your ticket size,
            which story points you told, and two or three things to fix next time. In
            Mystery mode, this is where the customer is revealed.
          </p>
        </section>

        <footer class="tut-controls">
          <button class="btn-ghost tut-nav" id="tut-back" type="button">Back</button>
          <div class="tut-dots" id="tut-dots" role="tablist" aria-label="Tutorial steps">
            <button class="tut-dot" type="button" data-go="0" aria-label="Step 1"></button>
            <button class="tut-dot" type="button" data-go="1" aria-label="Step 2"></button>
            <button class="tut-dot" type="button" data-go="2" aria-label="Step 3"></button>
            <button class="tut-dot" type="button" data-go="3" aria-label="Step 4"></button>
            <button class="tut-dot" type="button" data-go="4" aria-label="Step 5"></button>
          </div>
          <button class="btn-end tut-nav" id="tut-next" type="button">Next</button>
          <button class="btn-primary tut-nav" id="tut-cta" type="button" hidden>Start Training</button>
        </footer>
      </div>
    </div>

    <script type="application/json" id="app-data" set:html={appData} />
    <script src="../scripts/app.js"></script>
  </body>
</html>
